# ============================================================================
# AIRFLOW CONFIGURATION TEMPLATE
# ============================================================================
# This file shows all environment variables that can be configured.
# Copy this to .env and fill in the values.
#
# For the YouTube Ingestion DAG, you have two options:
#
# OPTION 1: Use this .env file (development/testing)
#   - Set all variables here with AIRFLOW_CONN_* and AIRFLOW_VAR_* prefixes
#   - Restart Docker Compose: docker compose down && docker compose up -d
#   - Airflow will auto-load them
#
# OPTION 2: Use Airflow UI (recommended for production/learning)
#   - Keep only AIRFLOW_UID and _PIP_ADDITIONAL_REQUIREMENTS in .env
#   - Add variables and connections via Airflow web UI
#   - No restart needed; changes take effect immediately
#
# ============================================================================

# Required: User ID for Airflow files in Docker
AIRFLOW_UID=50000

# Required: Install the YouTube API client inside Airflow containers
_PIP_ADDITIONAL_REQUIREMENTS=google-api-python-client

# ============================================================================
# OPTION 1 ONLY: If using .env approach, uncomment and fill these:
# ============================================================================

# Postgres Connection (Connection ID: postgres_local)
# Format: postgresql://username:password@host:port/database
# AIRFLOW_CONN_POSTGRES_LOCAL=postgresql://project:project@postgres-data:5432/project_db

# YouTube API Key (Variable: YOUTUBE_API_KEY)
# Get this from: https://console.developers.google.com/
# AIRFLOW_VAR_YOUTUBE_API_KEY=your_youtube_api_key_here

# YouTube Regions (Variable: YOUTUBE_REGIONS)
# Comma-separated region codes for trending videos
# AIRFLOW_VAR_YOUTUBE_REGIONS=US,GB,CA,DE,FR,IN,JP,KR,MX,RU

# Postgres Connection ID (Variable: POSTGRES_CONN_ID)
# This should match the connection ID you created
# AIRFLOW_VAR_POSTGRES_CONN_ID=postgres_local
